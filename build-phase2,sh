#!/bin/bash
set -e

# ============================================
# German Learning App — Phase 2 Build Script
# ============================================
#
# Runs AFTER build-overnight.sh (Phases 1-6) has already completed.
# The original Phase 1-6 build did NOT include:
#   - A defined design system (fonts, color palette, CSS variables)
#   - Error handling hardening
#   - Design consistency audit
# So this script handles all of that FIRST, then adds features.
#
# Usage: ./build-phase2.sh
# Resume: ./build-phase2.sh <phase_number>
#
# Phase 7:     Design system + Error handling retrofit
# Phases 8-10: Features (Sonnet, merged pairs)
# Phase 11:    Comprehensive test suite (Sonnet)
# Phases 12-13: Review passes (Sonnet)
# Phase 14:    Final review + verification (Opus)
#
# Estimated cost: $70–100 (cap: $144)
# ============================================

REPO_DIR="$(pwd)"
LOG_FILE="build-phase2-log-$(date +%Y%m%d-%H%M%S).txt"

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

log()        { echo -e "${GREEN}[$(date +%H:%M:%S)]${NC} $1" | tee -a "$LOG_FILE"; }
error()      { echo -e "${RED}[$(date +%H:%M:%S)] ERROR:${NC} $1" | tee -a "$LOG_FILE"; }
warn()       { echo -e "${YELLOW}[$(date +%H:%M:%S)] WARNING:${NC} $1" | tee -a "$LOG_FILE"; }
review_log() { echo -e "${CYAN}[$(date +%H:%M:%S)] REVIEW:${NC} $1" | tee -a "$LOG_FILE"; }

check_prereqs() {
    log "Checking prerequisites..."
    command -v claude &> /dev/null || { error "Claude Code CLI not found."; exit 1; }
    [ -n "$ANTHROPIC_API_KEY" ]   || { error "ANTHROPIC_API_KEY not set."; exit 1; }
    [ -f "CLAUDE.md" ]            || { error "CLAUDE.md not found. Are you in the project directory?"; exit 1; }
    [ -d "client/src" ]           || { error "Phase 1-6 build not found. Run build-overnight.sh first."; exit 1; }
    log "All prerequisites met."
}

commit_phase() {
    local phase_num=$1
    local phase_name=$2
    cd "$REPO_DIR"
    git add -A
    git commit -m "Phase $phase_num: $phase_name [autonomous build]" || warn "Nothing to commit for Phase $phase_num"
    git push origin main || error "Push failed for Phase $phase_num. Continuing."
    log "Phase $phase_num committed and pushed."
}

run_phase() {
    local phase_num=$1
    local phase_name=$2
    local model=$3
    local budget=$4
    local prompt=$5

    log "============================================"
    log "PHASE $phase_num: $phase_name"
    log "Model: $model | Budget cap: \$$budget"
    log "============================================"

    cd "$REPO_DIR"

    claude -p "$prompt" \
        --dangerously-skip-permissions \
        --model "$model" \
        --max-budget-usd "$budget" \
        2>&1 | tee -a "$LOG_FILE"

    [ ${PIPESTATUS[0]} -ne 0 ] && warn "Phase $phase_num exited non-zero. Committing progress."
    commit_phase "$phase_num" "$phase_name"
    log "Phase $phase_num complete."
    echo "" >> "$LOG_FILE"
}


